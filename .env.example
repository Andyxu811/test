# Postgres
# 优先推荐 Vercel Marketplace 的 Neon 集成。
# 线上至少需要一组可用连接：
# 1) 直接使用 Vercel 注入的 POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING
# 2) 或手动补齐 DATABASE_URL / DIRECT_URL（推荐把它们复制成同样的值，便于 Prisma CLI 和本地脚本复用）
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/tennis_growth_panel?schema=public"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/tennis_growth_panel?schema=public"

# 如果你直接使用 Vercel / Neon 自动注入变量，也可以保留下面两项并填同样的值。
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@127.0.0.1:5432/tennis_growth_panel?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@127.0.0.1:5432/tennis_growth_panel?schema=public"

# Vercel Blob（线上必填）
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Session / auth（线上必填）
AUTH_SECRET="replace-with-a-long-random-secret"
