{
  "name": "tennis-growth-panel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "node scripts/setup-db.mjs",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "npm run db:migrate:deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "node scripts/setup-db.mjs --reset && node prisma/seed.mjs",
    "setup": "npm run db:generate && npm run db:migrate:deploy && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "6.18.0",
    "@vercel/blob": "^2.3.2",
    "lucide-react": "^0.545.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "6.18.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
